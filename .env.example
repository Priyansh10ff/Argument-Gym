# ─── LLM Provider (OpenAI-compatible) ────────────────────────────────────────
# Defaults to OpenRouter — free tier at https://openrouter.ai/keys
PRIMARY_LLM_API_KEY=your_openrouter_api_key_here
PRIMARY_LLM_BASE_URL=https://openrouter.ai/api/v1
PRIMARY_LLM_MODEL=qwen/qwen3-plus:free

# Other providers:
#   OpenAI:  PRIMARY_LLM_BASE_URL=https://api.openai.com/v1  MODEL=gpt-4o-mini
#   Groq:    PRIMARY_LLM_BASE_URL=https://api.groq.com/openai/v1  MODEL=llama-3.3-70b-versatile
#   Ollama:  PRIMARY_LLM_BASE_URL=http://localhost:11434/v1  MODEL=llama3.2

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# ─── CORS (dev only — ignored when NODE_ENV=production) ───────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Environment ──────────────────────────────────────────────────────────────
# Set to "production" to serve built frontend from backend/public
NODE_ENV=development
