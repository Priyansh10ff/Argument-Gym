# ─── LLM Provider (OpenAI-compatible) ────────────────────────────────────────
# The backend uses the OpenAI SDK and connects to any OpenAI-compatible endpoint.
# Defaults to OpenRouter — get a free key at https://openrouter.ai/keys

PRIMARY_LLM_API_KEY=your_openrouter_api_key_here
PRIMARY_LLM_BASE_URL=https://openrouter.ai/api/v1
PRIMARY_LLM_MODEL=qwen/qwen3-plus:free

# To use a different provider, swap the base URL and model, e.g.:
#   OpenAI:      PRIMARY_LLM_BASE_URL=https://api.openai.com/v1
#                PRIMARY_LLM_MODEL=gpt-4o-mini
#   Groq:        PRIMARY_LLM_BASE_URL=https://api.groq.com/openai/v1
#                PRIMARY_LLM_MODEL=llama-3.3-70b-versatile

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# ─── CORS (development only) ──────────────────────────────────────────────────
# Only required when NODE_ENV is not "production".
# In production, the backend serves the built frontend and CORS is open (*).
FRONTEND_URL=http://localhost:5173

# ─── Environment ──────────────────────────────────────────────────────────────
# Set to "production" to enable static file serving from backend/public.
# Leave unset or set to "development" for local dev with separate Vite server.
NODE_ENV=development
